#!/bin/sh

set -e
set -u

if [ $# -ne 2 ]
then
    echo "error: two arguments required"
    exit 1
fi

writefile=$1
writesrt=$2

dirpath=$(dirname "writefile")
mkdir -p "$dirpath"

if [ $? -ne 0 ]
then
   echo "error: could not create directory $dirpath"
   exit 1
fi

echo "$writestr" > "$writefile"

if [ $? -ne 0 ]
then 
    echo "error: could not create file $writefile"
exit 1
fi
